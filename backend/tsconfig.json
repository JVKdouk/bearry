{
  "compilerOptions": {
    "target": "es2016",
    "module": "es2022",
    "moduleResolution": "bundler",
    "lib": ["es2024"],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": ["src/**/*", "core/**/*", "tests/**/*", "index.ts"],
  "files": ["index.ts"],
  "exclude": [
    "node_modules",
    "dist",
    ".dagger",
    "scripts",
    "logs",
    ".husky"
  ]
}
