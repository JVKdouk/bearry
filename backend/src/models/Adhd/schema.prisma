/// ─────────────────────────────────────────────────────────────────────────
/// The ADHD "doing" layer (§8.11–8.16) + templates/reminders/time-tracking.
/// Mostly low-sensitivity signals and config; the few content-bearing fields
/// are encrypted.
/// ─────────────────────────────────────────────────────────────────────────

/// Backs focus mode / body-doubling and the gentle "you focused N times today"
/// acknowledgment (§8.11). Low-sensitivity.
model FocusSession {
  id              String    @id @default(cuid())
  userId          String
  blockId         String?
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  plannedDuration Int?      /// minutes
  completed       Boolean   @default(false)

  updatedAt DateTime @updatedAt
  version   Int      @default(1)

  @@index([userId])
  @@map("focus_sessions")
}

enum ReminderKind {
  time
  location
  resurface
}

/// Externalized/location reminders and resurfacing (§8.14). Geofence coords are
/// sensitive, so `triggerSpec` is encrypted.
model Reminder {
  id          String       @id @default(cuid())
  userId      String
  targetType  String
  targetId    String
  kind        ReminderKind @default(time)
  triggerSpec String       /// (enc) JSON: time or geofence params
  delivered   Boolean      @default(false)

  /// When this fires. CLEARTEXT and indexed, deliberately: the delivery sweep
  /// has to find what's due across all users every minute, and doing that
  /// against an encrypted column would mean decrypting every reminder of every
  /// user on every tick — the exact mass-decrypt the rate limiter exists to
  /// stop (§5.4, §9.7). A timestamp reveals that *something* is scheduled, not
  /// what it is; the title stays encrypted and is only decrypted for the
  /// handful actually being sent.
  fireAt DateTime?

  /// Minutes before the target's start. 0 = at the time itself. Kept alongside
  /// `fireAt` so a reminder can be re-derived when the task moves, rather than
  /// being orphaned at a time that no longer relates to anything.
  offsetMinutes Int @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  version   Int       @default(1)
  deletedAt DateTime?

  @@index([userId])
  @@index([userId, delivered])
  /// The delivery sweep's exact query shape.
  @@index([fireAt, delivered])
  /// Delta-sync hot path.
  @@index([userId, updatedAt])
  @@map("reminders")
}

/// A device registered for Web Push.
///
/// Endpoint and keys are cleartext, which is safe for a specific reason: Web
/// Push will only deliver to an endpoint when the request is signed with our
/// VAPID private key, and that lives in the environment, never in the
/// database. A dump of this table therefore does not let anyone push anything
/// to a user's device — it reveals only that they use a given browser vendor's
/// push service.
model PushSubscription {
  id       String @id @default(cuid())
  userId   String
  /// The push service URL. Unique across users: a device that re-subscribes
  /// with the same endpoint is the same device, not a second one.
  endpoint String @unique
  p256dh   String
  auth     String
  /// For showing the user which devices are registered.
  label    String?

  /// Consecutive delivery failures. A subscription that keeps failing is a
  /// device that's gone; retrying it forever wastes a request per reminder.
  failureCount Int @default(0)
  lastUsedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("push_subscriptions")
}

/// Derived (not self-reported) signals that drive the overwhelm detector and the
/// Just-One-Thing default (§8.13). Cleartext aggregate metrics, no content.
model UserState {
  id                   String   @id @default(cuid())
  userId               String   @unique
  overdueCount         Int      @default(0)
  recentRescheduleRate Float    @default(0)
  daysSinceActive      Int      @default(0)
  overwhelmScore       Float    @default(0)
  updatedAt            DateTime @updatedAt

  @@map("user_states")
}

/// Calm-mode, notification-quiet, momentum-on/off, initiation toggles (§8.16).
/// Forgiving defaults mean an untouched Setting set still yields a good UX.
model Setting {
  id     String @id @default(cuid())
  userId String
  key    String
  value  String

  updatedAt DateTime  @updatedAt
  version   Int       @default(1)
  // Every other syncable carries a tombstone; without it the sync engine's
  // delete path (which writes deletedAt) fails permanently for settings.
  deletedAt DateTime?

  @@unique([userId, key])
  // Delta-sync hot path: WHERE userId = ? AND updatedAt > ? ORDER BY updatedAt.
  @@index([userId, updatedAt])
  @@map("settings")
}

enum TemplateKind {
  project
  day
  routine
}

/// Reusable project/day/routine structures the scheduler instantiates (§8.8).
/// Name + serialized payload encrypted.
model Template {
  id         String       @id @default(cuid())
  userId     String
  kind       TemplateKind
  name       String       /// (enc)
  payload    String       /// (enc) serialized tasks/blocks/durations
  lastUsedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  version   Int       @default(1)
  deletedAt DateTime?

  @@index([userId])
  @@map("templates")
}

/// Optional, off-by-default estimate-vs-actual tracking (§8.9). Low-sensitivity
/// metadata used only to refine future estimates — never billing.
model TimeLog {
  id                String   @id @default(cuid())
  userId            String
  blockId           String
  estimatedDuration Int      /// minutes
  actualDuration    Int      /// minutes
  completedAt       DateTime @default(now())

  version Int @default(1)

  @@index([userId])
  @@index([blockId])
  @@map("time_logs")
}
