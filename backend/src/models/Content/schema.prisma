/// ─────────────────────────────────────────────────────────────────────────
/// Content domain (§7). Fields whose name/comment marks them *(enc)* store a
/// base64 packed sealed value (§5.8); everything else is cleartext structural
/// metadata the scheduler and filters query. Every syncable row carries
/// `updatedAt` + `version` + `deletedAt` for delta sync (§ Phase 2, item 8).
/// ─────────────────────────────────────────────────────────────────────────

enum Priority {
  ASAP
  high
  medium
  low
}

enum EnergyLevel {
  high
  medium
  low
}

/// How much the user actually WANTS to do a task — orthogonal to how demanding
/// it is. A 20-minute phone call can be low-energy and still dreaded, and that
/// dread is what actually decides whether it happens. The scheduler treats
/// `avoided` work as the thing to protect: placed early, kept short, never
/// stacked, and capped per day.
enum Desire {
  wanted
  neutral
  avoided
}

enum TodoStatus {
  todo
  in_progress
  done
}

/// What a block *is*, which is really a statement about two independent
/// properties: whether you act on it, and whether it occupies time.
///
///   task  — actionable. May or may not be scheduled.
///   event — occupies time, but there is nothing to do about it. It completes
///           itself by happening.
///   note  — neither. Reference material that belongs beside the work.
///
/// These were three tables, which meant "turn this note into a task" was a
/// delete plus an insert plus repointing every step, link and reminder — and
/// meant the Today screen had to merge two queries with different shapes and
/// pretend the result was one list. They are one row now, and converting is a
/// field assignment.
enum BlockKind {
  task
  event
  note
}

/// Where a block came from. `local` is anything the user made here; the rest
/// are owned by an external calendar or task service and re-imported.
enum BlockSource {
  local
  google
  ticktick
}

/// Groups todos. `name` is encrypted; color/order/archived are cleartext.
model Project {
  id       String  @id @default(cuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name     String  /// (enc)
  color    String  @default("#832062")
  /// A single emoji. Cleartext: it carries no content, and keeping it readable
  /// is what lets the sidebar render a list without a decryption round-trip.
  /// Emoji rather than a named icon set — it needs no mapping table, renders
  /// everywhere, and the user isn't limited to what someone drew.
  icon     String?
  order    Float   @default(0)
  archived Boolean @default(false)

  blocks Block[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  version   Int       @default(1)
  deletedAt DateTime?

  // Delta-sync hot path: WHERE userId = ? AND updatedAt > ? ORDER BY updatedAt.
  @@index([userId, updatedAt])
  @@map("projects")
}

/// One row for everything that lives on a board or a calendar.
///
/// `kind` decides behaviour, not the table: a task is actionable, an event
/// occupies time without being actionable, a note is neither. Fields that only
/// make sense for one kind are nullable rather than split into another table —
/// the alternative was three models with three sync entities, three sets of
/// controllers, and a conversion path that had to move foreign keys.
///
/// `title`/`body`/`location` are encrypted; everything the scheduler and the
/// calendar query — times, priority, duration, recurrence — stays cleartext so
/// busy-time queries and the solver run without a decryption round-trip
/// (§5.2, §7.3, §9.7).
model Block {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  kind BlockKind @default(task)

  /// Self-referential nesting (§7.2). UI caps depth ~4–5.
  parentId String?
  parent   Block?  @relation("BlockTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Block[] @relation("BlockTree")

  title String  /// (enc)
  /// (enc) markdown. A task's notes, an event's description and a note's whole
  /// body were three differently-named columns holding the same thing.
  body  String?
  /// (enc) events only.
  location String?

  /// Only meaningful for tasks. An event completes by happening and a note is
  /// never done, so both simply leave this at its default.
  status   TodoStatus @default(todo)
  priority Priority   @default(medium)
  deadline DateTime?

  /// A block with a start and an end occupies time and draws on the calendar.
  /// Required in practice for events; optional for tasks, which may be
  /// scheduled or not.
  startTime DateTime?
  endTime   DateTime?

  /// Life area for time blocking (§8.4), matched against BlockRegion.category.
  category LifeArea?

  /// minutes; a gentle default so a task is never blocked on an estimate (§7.3).
  estimatedDuration Int         @default(30)
  energyDemand      EnergyLevel @default(medium)
  /// How much you want to do this, as opposed to how hard it is.
  desire            Desire      @default(neutral)
  /// Whether the planner may split this across several sittings. Nullable on
  /// purpose: null means nobody has decided, which is different from an
  /// explicit no, and unset falls back to a duration rule (chunking.ts).
  chunkable         Boolean?
  minChunk          Int?    /// minutes
  maxChunk          Int?    /// minutes
  recurrenceRule    String? /// RFC 5545 RRULE

  /// "mornings only" style hints, JSON-encoded window descriptors (cleartext).
  preferredWindows String?

  /// Timestamp a stale task was gently let go without guilt (§1.4 p2). Recoverable.
  letGoAt DateTime?

  order Float @default(0)

  // ── externally-owned blocks ────────────────────────────────────────────
  source     BlockSource @default(local)
  /// Provider id, for idempotent re-import (§6.4).
  externalId String?
  /// Fields the user has edited by hand on an IMPORTED block, which the
  /// importer must therefore stop overwriting. Comma-separated field names.
  /// Without it, editing an imported event is a lie: the change saves, looks
  /// applied, and is silently reverted on the next sync.
  pinnedFields String?

  // ── planner output ─────────────────────────────────────────────────────
  /// An immovable commitment the scheduler must never move (§9.3).
  isFixed Boolean @default(false)
  /// Set on planner-placed blocks: the task this block is doing time for.
  planForId String?
  planFor   Block?  @relation("BlockPlan", fields: [planForId], references: [id], onDelete: Cascade)
  planBlocks Block[] @relation("BlockPlan")
  /// The solver's plain-language reason for this placement (§9.6). Cleartext —
  /// template-filled from the decision trace, not user content.
  scheduleReason String?

  /// Which model name this row's ciphertext was sealed under, while it still
  /// differs from "Block". The AAD binds userId:Model:field, so rows carried
  /// over from todos/calendar_events/notes cannot be opened as "Block" until
  /// they have been re-sealed. The re-encryption pass clears this, and the
  /// column is dropped once every row reads null.
  legacyAadModel String?

  steps TaskStep[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  version   Int       @default(1)
  deletedAt DateTime?

  @@index([projectId])
  @@index([parentId])
  @@index([userId, kind, status])
  @@index([userId, kind, deadline])
  /// Calendar range queries: everything drawable in a window.
  @@index([userId, startTime])
  @@index([userId, source, externalId])
  @@index([planForId])
  // Delta-sync hot path: WHERE userId = ? AND updatedAt > ? ORDER BY updatedAt.
  @@index([userId, updatedAt])
  @@map("blocks")
}

/// A break-it-down sub-step for task initiation (§8.11). `text` encrypted;
/// `isFirstStep` marks the highlighted "start here" action.
model TaskStep {
  id          String  @id @default(cuid())
  userId      String
  blockId     String
  block       Block   @relation(fields: [blockId], references: [id], onDelete: Cascade)
  text        String  /// (enc)
  order       Float   @default(0)
  isFirstStep Boolean @default(false)
  done        Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  version   Int       @default(1)
  deletedAt DateTime?

  @@index([blockId])
  // Delta-sync hot path: WHERE userId = ? AND updatedAt > ? ORDER BY updatedAt.
  @@index([userId, updatedAt])
  @@map("task_steps")
}

/// What a link can point at. The three content kinds collapsed into `block`
/// when the tables did — a link to "the todo" and a link to "the event" were
/// always the same edge with a different label.
enum LinkFromType {
  block
  capture
}

enum LinkType {
  reference
  derived_from
  blocks
}

/// Bidirectional link (§8.7). The *fact* of a link is low-sensitivity structural
/// data (cleartext); the linked content stays encrypted on its own row.
model Link {
  id       String       @id @default(cuid())
  userId   String
  fromType LinkFromType
  fromId   String
  toType   LinkFromType
  toId     String
  linkType LinkType     @default(reference)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  version   Int       @default(1)
  deletedAt DateTime?

  @@index([fromType, fromId])
  @@index([toType, toId])
  // Delta-sync hot path: WHERE userId = ? AND updatedAt > ? ORDER BY updatedAt.
  @@index([userId, updatedAt])
  @@map("links")
}
