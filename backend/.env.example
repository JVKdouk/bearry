DATABASE_URL="postgresql://postgres:@localhost:5432/bearry?schema=public"
NODE_ENV=development
SERVER_PORT=10003
# Session JWT signing secret. MUST be >= 32 chars of high entropy — the server
# refuses to boot otherwise. Generate: openssl rand -base64 48
JWT_SECRET="<openssl rand -base64 48>"
FRONT_END_ORIGIN="http://localhost:20000"
COOKIE_DOMAIN="localhost"
HOSTNAME="0.0.0.0"

# Root KEK — the single trust anchor (§5.1). 32 bytes base64. Held only in
# process memory; kept OFF Postgres and OFF the DB host. The server refuses to
# boot without it. Generate: openssl rand -base64 32
#
# Production: split into two XOR shares from different sources (§14.1) so no
# single leaked artifact reveals it:
#   ROOT_KEK_SHARE_A="<share from orchestrator secret store>"
#   ROOT_KEK_SHARE_B="<share from read-only env mount>"
ROOT_KEK="<openssl rand -base64 32>"

# Active-only DEK cache TTL (§5.3). Shorter = smaller takeover blast radius.
DEK_TTL_SECONDS=1200

# Decrypt rate limiter (§5.4). The distinct-users cap is the anti-mass-exfil
# control; records is a generous per-user secondary guard.
# DECRYPT_MAX_USERS=5
# DECRYPT_MAX_RECORDS=100000

# Google OAuth (Phase 4 — token store works without these; live sync needs them)
# GOOGLE_CLIENT_ID="<your google client id>"
# GOOGLE_CLIENT_SECRET="<your google client secret>"

# Per-user AI budget. Charged in ITEMS, not requests — asking about 50 tasks
# costs fifty times what asking about one does. Sized so ordinary use never
# notices while a runaway loop is stopped in seconds.
# AI_BUDGET_MAX_ITEMS=300
# AI_BUDGET_WINDOW_SECONDS=3600

# Tombstone retention. OFF by default: this is the one background job that
# permanently removes rows, and a deploy should never start deleting data as a
# side effect of shipping. Clients whose sync cursor predates the window are
# served a full re-bootstrap, which is what makes pruning safe — shortening
# RETENTION_DAYS below a realistic offline period is NOT safe.
# TOMBSTONE_SWEEP_ENABLED=true
# TOMBSTONE_RETENTION_DAYS=90

# Scheduled digests. OFF by default so a developer running the server locally
# never emails real users. Delivery is idempotent per user per period, so the
# hourly check cannot produce a duplicate.
# DIGEST_SCHEDULE_ENABLED=true
# DIGEST_DAILY_HOUR=7
# DIGEST_WEEKLY_HOUR=18
# DIGEST_WEEKLY_DAY=0

# Email. Gmail is the primary transport; GMAIL_APP_PASSWORD must be a Google
# App Password (16 chars, 2FA required) — a plain account password fails with a
# confusing "Username and Password not accepted".
# GMAIL_USER="you@gmail.com"
# GMAIL_APP_PASSWORD="<app password>"
# MAILER_FROM="Bearry <you@gmail.com>"

# Registration is CLOSED unless this is exactly "true". Local test accounts
# need it set.
# SIGNUPS_OPEN=true

# Web Push. Generate with: npx web-push generate-vapid-keys --json
# Without these, push stays off and the settings page says so rather than
# offering a toggle that silently does nothing. The private key never goes in
# the database — that's what makes storing subscription endpoints in cleartext
# safe, since an endpoint alone can't be pushed to.
# VAPID_PUBLIC_KEY="<public key>"
# VAPID_PRIVATE_KEY="<private key>"
# VAPID_SUBJECT="mailto:you@example.com"

# How late a reminder can be and still be worth sending. A server down
# overnight must NOT come back and fire a burst of notifications for things
# that already happened.
# REMINDER_MAX_LATENESS_MINUTES=60
# REMINDER_TICK_SECONDS=60
